generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  password            String
  role                String
  emailVerified       Boolean   @default(false)
  verificationToken   String?
  resetOtp            String?
  resetOtpExpiry      DateTime?
  createdAt           DateTime  @default(now())
  student             Student?
  employer            Employer?
  notifications       Notification[]
}
model Student {
  id                String   @id @default(cuid())
  userId            String   @unique
  university        String?
  faculty           String?
  department        String?
  year              Int?
  gpa               Float?
  bio               String?
  skills            String?
  cvUrl             String?
  photoUrl          String?
  jobAlertsEnabled  Boolean  @default(true)   // ← add this
  createdAt         DateTime @default(now())
  user              User          @relation(fields: [userId], references: [id])
  applications      Application[]
}

model Employer {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String
  industry    String?
  website     String?
  logoUrl     String?
  description String?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id])
  listings    Listing[]
}

model Listing {
  id          String    @id @default(cuid())
  employerId  String
  title       String
  description String
  skills      String?
  location    String?
  duration    String?
  stipend     String?
  deadline    DateTime?
  openings    Int       @default(1)
  status      String    @default("open")
  createdAt   DateTime  @default(now())

  employer     Employer       @relation(fields: [employerId], references: [id])
  applications Application[]
  slots        InterviewSlot[]
}

model Application {
  id             String   @id @default(cuid())
  studentId      String
  listingId      String
  status         String   @default("applied")
  coverLetterUrl String?
  appliedAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student        Student  @relation(fields: [studentId], references: [id])
  listing        Listing  @relation(fields: [listingId], references: [id])
  messages       Message[]

  @@unique([studentId, listingId])
}

model InterviewSlot {
  id         String   @id @default(cuid())
  listingId  String
  datetime   DateTime
  bookedById String?
  confirmed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  listing    Listing  @relation(fields: [listingId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  authorId   String
  targetId   String
  targetType String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id])
}

model Message {
  id            String   @id @default(cuid())
  applicationId String
  senderId      String
  content       String
  createdAt     DateTime @default(now())

  application   Application @relation(fields: [applicationId], references: [id])
}